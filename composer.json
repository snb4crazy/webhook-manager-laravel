{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "snb4crazy/webhook-manager-laravel",
    "description": "Queue-aware webhook sender and signature verifier for Laravel apps.",
    "keywords": ["laravel", "webhook", "hmac", "queue", "retry"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Serhii Dymenko",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/queue": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.0|^8.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "WebhookManager\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebhookManager\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WebhookManager\\Laravel\\WebhookManagerServiceProvider"
            ],
            "aliases": {
                "Webhook": "WebhookManager\\Laravel\\Facades\\Webhook"
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

